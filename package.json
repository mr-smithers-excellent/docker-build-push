{
  "name": "docker-build-push-action",
  "version": "5.7.0",
  "description": "Docker Build & Push Action",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/main.js --bundle --platform=node --outfile=dist/index.js --format=cjs --conditions=import",
    "precommit": "npm run build && git add dist/",
    "lint": "eslint 'src/**.js' 'tests/**.js' --fix",
    "test": "eslint 'src/**.js' 'tests/**.js' && NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:watch": "npm run test -- --watchAll",
    "prepare": "husky install"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run precommit"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mr-smithers-excellent/docker-build-push-action.git"
  },
  "keywords": [
    "GitHub",
    "Actions",
    "Docker",
    "GCR",
    "ECR",
    "Docker Hub"
  ],
  "author": "Sean Smith",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mr-smithers-excellent/docker-build-push-action/issues"
  },
  "homepage": "https://github.com/mr-smithers-excellent/docker-build-push-action#readme",
  "dependencies": {
    "18": "^0.0.0",
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.1.0",
    "dayjs": "^1.11.20"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "mockdate": "^3.0.5",
    "prettier": "^3.8.2"
  },
  "jest": {
    "transform": {}
  }
}
